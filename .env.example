# Alarm Monitor configuration
# Legacy deployments may still use the ALARM_DASHBOARD_ prefix (read as fallback).

# API Key for receiving alarms from alarm-mail service (required)
# Generate with: openssl rand -hex 32
ALARM_MONITOR_API_KEY=change-me-to-random-api-key

# Password for the settings page (required to save settings via the web UI)
# Generate with: openssl rand -hex 16
ALARM_MONITOR_SETTINGS_PASSWORD=change-me-to-random-settings-password

# Optional alarm messenger integration for participant responses
# When MESSENGER_SERVER_URL is set, participant responses will be polled and displayed
ALARM_MONITOR_MESSENGER_SERVER_URL=https://messenger.example.com
ALARM_MONITOR_MESSENGER_API_KEY=your-messenger-api-key-here

# Optional activation filters (comma-separated TME codes or group names)
# Note: This can now be configured in the web interface under Settings
# ALARM_MONITOR_GRUPPEN=
ALARM_MONITOR_DISPLAY_DURATION_MINUTES=30

# Optional display customization
# Note: Fire department name can now be configured in the web interface under Settings
# ALARM_MONITOR_FIRE_DEPARTMENT_NAME=

# Optional defaults for idle weather display (Settings → Ruhezustand)
# ALARM_MONITOR_DEFAULT_LATITUDE=
# ALARM_MONITOR_DEFAULT_LONGITUDE=
# ALARM_MONITOR_DEFAULT_LOCATION_NAME=

# Optional overrides for external services
# ALARM_MONITOR_NOMINATIM_URL=https://nominatim.openstreetmap.org/search
# ALARM_MONITOR_WEATHER_URL=https://api.open-meteo.com/v1/forecast
# ALARM_MONITOR_WEATHER_PARAMS=current_weather=true&hourly=precipitation,precipitation_probability,rain,showers,snowfall&forecast_days=1
# ALARM_MONITOR_DWD_WARNINGS_URL=https://s3.eu-central-1.amazonaws.com/app-prod-static.warnwetter.de/v16/gemeinde_warnings_v2.json

# Show last alarm in idle view (left panel); when false, weather warnings stay left permanently
# Can also be toggled in Settings → "Letzten Einsatz im Ruhezustand anzeigen"
# ALARM_MONITOR_SHOW_LAST_ALARM=true

# Minimum DWD warning level shown in idle view (1–4; default: 3 = Unwetterwarnung)
# Can also be set in Settings → Ruhezustand → "Mindest-Warnstufe für Anzeige"
# ALARM_MONITOR_WARNINGS_MIN_LEVEL=3

# Simulate a severe weather warning in idle mode (for testing the UI)
# Can also be toggled in Settings → "Unwetterwarnung simulieren (Test)"
# ALARM_MONITOR_DWD_WARNINGS_MOCK=true

# Gunicorn worker/thread count – keep workers=1 to avoid split-brain with in-process state.
# ALARM_MONITOR_GUNICORN_WORKERS=1
# ALARM_MONITOR_GUNICORN_THREADS=8

# Prometheus metrics endpoint token (required to enable /api/metrics)
# Generate with: openssl rand -hex 32
# ALARM_MONITOR_METRICS_TOKEN=change-me-to-random-metrics-token

# Optional ntfy.sh integration for remote dashboard messages
# Create a topic on https://ntfy.sh (or your own ntfy server) and set the URL here.
# Messages posted to the topic will appear on the standby dashboard.
# Example: ALARM_MONITOR_NTFY_TOPIC_URL=https://ntfy.sh/my-fw-abc123
# ALARM_MONITOR_NTFY_TOPIC_URL=
# ALARM_MONITOR_NTFY_POLL_INTERVAL=60

# Optional: path for persisted messages file (must be under /app/instance/)
# ALARM_MONITOR_MESSAGES_FILE=/app/instance/messages.json
# Maximum TTL for a dashboard message in hours (default: 72)
# ALARM_MONITOR_MESSAGE_MAX_TTL_HOURS=72

# Optional: HDMI-CEC display control (monitor/TV power via cec-client).
# cec-client is bundled in the Docker image; pass /dev/cec0 into the container.
# ALARM_MONITOR_CEC_ENABLED=true
# ALARM_MONITOR_CEC_CLIENT_PATH=/usr/bin/cec-client
# ALARM_MONITOR_CEC_DEVICE_ADDRESS=0
# ALARM_MONITOR_CEC_IDLE_STANDBY_MINUTES=30
# ALARM_MONITOR_CEC_WAKE_ON_ALARM=true
# ALARM_MONITOR_CEC_STANDBY_ON_IDLE=true
# Most options can also be configured in Settings → HDMI-CEC.
