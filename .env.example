# Alarm Dashboard configuration

# API Key for receiving alarms from alarm-mail service (required)
# Generate with: openssl rand -hex 32
ALARM_DASHBOARD_API_KEY=change-me-to-random-api-key

# Password for the settings page (required to save settings via the web UI)
# Generate with: openssl rand -hex 16
ALARM_DASHBOARD_SETTINGS_PASSWORD=change-me-to-random-settings-password

# Optional alarm messenger integration for participant responses
# When MESSENGER_SERVER_URL is set, participant responses will be polled and displayed
ALARM_DASHBOARD_MESSENGER_SERVER_URL=https://messenger.example.com
ALARM_DASHBOARD_MESSENGER_API_KEY=your-messenger-api-key-here

# Optional activation filters (comma-separated TME codes or group names)
# Note: This can now be configured in the web interface under Settings
# ALARM_DASHBOARD_GRUPPEN=
ALARM_DASHBOARD_DISPLAY_DURATION_MINUTES=30

# Optional display customization
# Note: Fire department name can now be configured in the web interface under Settings
# ALARM_DASHBOARD_FIRE_DEPARTMENT_NAME=

# Optional defaults for idle weather display
# Note: These can now be configured in the web interface under Settings
# ALARM_DASHBOARD_DEFAULT_LATITUDE=
# ALARM_DASHBOARD_DEFAULT_LONGITUDE=
# ALARM_DASHBOARD_DEFAULT_LOCATION_NAME=

# Optional overrides for external services
# ALARM_DASHBOARD_NOMINATIM_URL=https://nominatim.openstreetmap.org/search
# ALARM_DASHBOARD_WEATHER_URL=https://api.open-meteo.com/v1/forecast
# ALARM_DASHBOARD_WEATHER_PARAMS=current_weather=true&hourly=precipitation,precipitation_probability,rain,showers,snowfall&forecast_days=1

# Gunicorn worker/thread count – keep workers=1 to avoid split-brain with in-process state.
# ALARM_DASHBOARD_GUNICORN_WORKERS=1
# ALARM_DASHBOARD_GUNICORN_THREADS=8

# Prometheus metrics endpoint token (required to enable /api/metrics)
# Generate with: openssl rand -hex 32
# ALARM_DASHBOARD_METRICS_TOKEN=change-me-to-random-metrics-token

# Optional ntfy.sh integration for remote dashboard messages
# Create a topic on https://ntfy.sh (or your own ntfy server) and set the URL here.
# Messages posted to the topic will appear on the standby dashboard.
# Example: ALARM_DASHBOARD_NTFY_TOPIC_URL=https://ntfy.sh/my-fw-abc123
# ALARM_DASHBOARD_NTFY_TOPIC_URL=
# ALARM_DASHBOARD_NTFY_POLL_INTERVAL=60

# Optional: path for persisted messages file (must be under /app/instance/)
# ALARM_DASHBOARD_MESSAGES_FILE=/app/instance/messages.json
# Maximum TTL for a dashboard message in hours (default: 72)
# ALARM_DASHBOARD_MESSAGE_MAX_TTL_HOURS=72
